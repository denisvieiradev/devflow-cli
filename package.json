{
  "name": "@denisvieiradev/devflow-cli",
  "version": "1.2.0",
  "description": "CLI pipeline for structured software development — from PRD to merge",
  "type": "module",
  "bin": {
    "devflow": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --passWithNoTests",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "cli",
    "devflow",
    "development-pipeline",
    "prd",
    "techspec",
    "code-review",
    "ai"
  ],
  "author": "Denis Vieira <denisvieira05@gmail.com> (https://github.com/denisvieiradev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denisvieiradev/devflow-cli.git"
  },
  "bugs": {
    "url": "https://github.com/denisvieiradev/devflow-cli/issues"
  },
  "homepage": "https://github.com/denisvieiradev/devflow-cli#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
